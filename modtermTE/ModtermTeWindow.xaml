<Window x:Class="modtermTE.ModtermTeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:modtermTE"
        mc:Ignorable="d"
        Title="modtermTE">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="33" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="33"
              VerticalAlignment="Top"
              Background="Transparent" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="32,8,32,24">
            <StackPanel x:Name="SettingsPanel"
                        Spacing="0"
                        MaxWidth="760"
                        HorizontalAlignment="Stretch" />
        </ScrollViewer>

        <Border Grid.Row="2"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="SaveConfigurationButton"
                        Content="Save Configuration"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SaveConfigurationButton_Click" />
                <Button x:Name="SaveAsNewThemeButton"
                        Content="Save as New Theme"
                        Click="SaveAsNewThemeButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
